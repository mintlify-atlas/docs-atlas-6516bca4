{
  "projectType": "cli-tool",
  "projectName": "Confluence Markdown Exporter",
  "projectDescription": "A CLI tool that exports Atlassian Confluence pages, spaces, and organizations to Markdown files via the Confluence REST API.",
  "theme": "palm",
  "primaryColor": "#e0c155",
  "lightColor": "#4a6a83",
  "darkColor": "#d5d6d3",
